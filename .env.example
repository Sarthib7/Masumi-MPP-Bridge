# OPERATOR ONLY — you are the only person who sets these variables.
#
# • Deploy this file as server/env secrets on YOUR host. Never send it to hirers.
# • Clients do NOT clone this repo, do NOT copy .env, and have NO bridge env vars to configure.
# • They only need the public bridge URL you give them + an MPP (e.g. Tempo) wallet.
#
# Copy to .env on the server and replace every placeholder with your own values.
#
# Shape reference:
#   PAYMENT_SERVICE_URL — https://<host>/api/v1 (must include /api/v1)
#   PAYMENT_API_KEY — Masumi Payment Service (registry + payment APIs). Not Sokosumi;
#     marketplace keys are different — see README “Payment Service vs Sokosumi”.
#   NETWORK — Preprod or Mainnet
#   MPP_SECRET_KEY — long random secret for mppx (e.g. openssl rand -hex 32)
#   MPP_RECIPIENT — Tempo wallet, 0x + 40 hex characters
#   BLOCKFROST_API_KEY — from blockfrost.io; preprod keys usually start with "preprod"
#
# Sokosumi (below): NOT required. Default is Masumi registry only (AGENT_CATALOG=registry).
# Add SOKOSUMI_API_KEY only if you want listings/prices from Sokosumi (sokosumi or both).

PORT=3002

PAYMENT_SERVICE_URL=https://masumi-payment-service-production-xxxx.up.railway.app/api/v1
PAYMENT_API_KEY=replace_with_key_from_masumi_admin
NETWORK=Preprod

MPP_SECRET_KEY=replace_with_long_random_secret
MPP_RECIPIENT=0x0000000000000000000000000000000000000000
MPP_TESTNET=true

BLOCKFROST_API_KEY=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Optional: Sokosumi marketplace catalog (operator-only) ---
# You do NOT need this block to run the bridge. Omit it unless you want agent discovery
# from Sokosumi as well as (or instead of) the Masumi registry.
#
#   AGENT_CATALOG=registry  → default if unset; only PAYMENT_* registry (no Sokosumi key).
#   AGENT_CATALOG=sokosumi → requires SOKOSUMI_API_KEY (Bearer). Listing from Sokosumi API.
#   AGENT_CATALOG=both     → merge Sokosumi + registry (key recommended for Sokosumi side).
#
#AGENT_CATALOG=both
#SOKOSUMI_API_URL=https://api.sokosumi.com/v1
#SOKOSUMI_API_KEY=your_sokosumi_bearer_key
# Credit-style prices × this = USD for MPP when the API does not send explicit USD (tune for your org).
#SOKOSUMI_CREDITS_TO_USD=0.01
