{
  "name": "masumi-mpp-bridge",
  "version": "0.1.0",
  "description": "Universal payment gateway bridging MPP to Masumi MIP-003 agents",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.19.0 || >=22.13.0 || >=24"
  },
  "bin": {
    "masumi-hire": "./dist/cli/hire-main.js"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "hire": "tsx src/cli/hire-main.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.0.0",
    "mppx": "^0.4.0",
    "viem": "^2.46.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.19.37",
    "eslint": "^9.39.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.57.1"
  }
}
